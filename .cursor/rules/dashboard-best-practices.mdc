## 2. Patrones de Visualización

### 2.1 Sankey Diagram (Pipeline Flow)

**Uso**: Mostrar flujo de documentos entre stages del pipeline.

```javascript
import * as d3Sankey from 'd3-sankey';

function PipelineSankeyChart({ data }) {
  const svgRef = useRef();
  
  useEffect(() => {
    // 1. Preparar datos
    const nodes = [
      { name: 'Pending' },
      { name: 'OCR' },
      { name: 'Chunking' },
      { name: 'Indexing' },
      { name: 'Insights' },
      { name: 'Completed' }
    ];
    
    const links = [
      { source: 0, target: 1, value: data.ocr_total },
      { source: 1, target: 2, value: data.chunking_total },
      // ...
    ];
    
    // 2. Crear layout Sankey
    const sankey = d3Sankey.sankey()
      .nodeWidth(15)
      .nodePadding(10)
      .extent([[1, 1], [width - 1, height - 6]]);
    
    const { nodes: sankeyNodes, links: sankeyLinks } = sankey({
      nodes: nodes.map(d => Object.assign({}, d)),
      links: links.map(d => Object.assign({}, d))
    });
    
    // 3. Renderizar
    const svg = d3.select(svgRef.current);
    
    // Links
    svg.selectAll('.link')
      .data(sankeyLinks)
      .join('path')
      .attr('class', 'link')
      .attr('d', d3Sankey.sankeyLinkHorizontal())
      .attr('stroke-width', d => Math.max(1, d.width))
      .on('click', (event, d) => {
        // Filtrar por stage
        updateFilter('stage', d.source.name);
      });
    
    // Nodes
    svg.selectAll('.node')
      .data(sankeyNodes)
      .join('rect')
      .attr('class', 'node')
      .attr('x', d => d.x0)
      .attr('y', d => d.y0)
      .attr('height', d => d.y1 - d.y0)
      .attr('width', d => d.x1 - d.x0);
      
  }, [data]);
  
  return <svg ref={svgRef} width={width} height={height}></svg>;
}
```

**Best Practices**:
- ✅ Tooltip en hover mostrando cantidad exacta
- ✅ Click en node/link para filtrar
- ✅ Color consistente por stage (usar VISUAL_ANALYTICS_GUIDELINES)
- ✅ Transición suave al actualizar datos

### 2.2 Timeline con Brush (Histórico)

**Uso**: Mostrar evolución temporal con zoom interactivo.

```javascript
import { brushX } from 'd3-brush';
import { scaleTime, scaleLinear } from 'd3-scale';
import { line } from 'd3-shape';

function ProcessingTimeline({ data }) {
  const svgRef = useRef();
  const { filters, updateFilter } = useDashboardFilters();
  
  useEffect(() => {
    const svg = d3.select(svgRef.current);
    const margin = { top: 20, right: 20, bottom: 30, left: 40 };
    const width = 800 - margin.left - margin.right;
    const height = 400 - margin.top - margin.bottom;
    
    // Scales
    const xScale = scaleTime()
      .domain(d3.extent(data, d => new Date(d.timestamp)))
      .range([0, width]);
    
    const yScale = scaleLinear()
      .domain([0, d3.max(data, d => d.count)])
      .range([height, 0]);
    
    // Line generator
    const lineGenerator = line()
      .x(d => xScale(new Date(d.timestamp)))
      .y(d => yScale(d.count))
      .curve(d3.curveMonotoneX); // Suavizado
    
    // Render line
    svg.select('.line-path')
      .datum(data)
      .attr('d', lineGenerator)
      .attr('fill', 'none')
      .attr('stroke', '#4dd0e1')
      .attr('stroke-width', 2);
    
    // Brush
    const brush = brushX()
      .extent([[0, 0], [width, height]])
      .on('end', (event) => {
        if (!event.selection) return;
        
        const [x0, x1] = event.selection;
        const timeRange = [xScale.invert(x0), xScale.invert(x1)];
        
        // Actualizar filtro global
        updateFilter('timeRange', timeRange);
      });
    
    svg.select('.brush-group')
      .call(brush);
      
  }, [data, filters]);
  
  return (
    <svg ref={svgRef} width={800} height={400}>
      <g className="main-group" transform={`translate(${margin.left},${margin.top})`}>
        <path className="line-path"></path>
        <g className="brush-group"></g>
      </g>
    </svg>
  );
}
```

**Best Practices**:
- ✅ Brush para zoom temporal
- ✅ Reset button si filtro aplicado
- ✅ Indicador visual de rango seleccionado
- ✅ Multi-líneas para comparar stages

### 2.3 Heatmap (Carga de Workers)

**Uso**: Visualizar carga de workers por hora del día.

```javascript
function WorkersHeatmap({ data }) {
  const svgRef = useRef();
  
  useEffect(() => {
    const svg = d3.select(svgRef.current);
    
    // Escalas
    const xScale = scaleBand()
      .domain(d3.range(0, 24)) // Horas 0-23
      .range([0, width])
      .padding(0.05);
    
    const yScale = scaleBand()
      .domain(['OCR', 'Insights', 'Indexing'])
      .range([0, height])
      .padding(0.05);
    
    const colorScale = scaleSequential(d3.interpolateRdYlGn)
      .domain([100, 0]); // 100% = rojo (saturado), 0% = verde (idle)
    
    // Renderizar celdas
    svg.selectAll('.heatmap-cell')
      .data(data)
      .join('rect')
      .attr('class', 'heatmap-cell')
      .attr('x', d => xScale(d.hour))
      .attr('y', d => yScale(d.worker_type))
      .attr('width', xScale.bandwidth())
      .attr('height', yScale.bandwidth())
      .attr('fill', d => colorScale(d.load_percentage))
      .on('click', (event, d) => {
        // Filtrar por worker y hora
        updateFilter('workerId', d.worker_id);
        updateFilter('timeRange', [d.hour, d.hour + 1]);
      });
      
  }, [data]);
  
  return <svg ref={svgRef} width={width} height={height}></svg>;
}
```

**Best Practices**:
- ✅ Color scale intuitivo (verde = bajo, rojo = alto)
- ✅ Tooltip con métricas exactas
- ✅ Click para filtrar por worker + hora
- ✅ Legend visible

### 2.4 Word Cloud (Keywords)

**Uso**: Mostrar palabras clave de insights.

```javascript
import cloud from 'd3-cloud';

function WordCloudViz({ keywords }) {
  const [words, setWords] = useState([]);
  
  useEffect(() => {
    const layout = cloud()
      .size([width, height])
      .words(keywords.map(d => ({ text: d.word, size: d.frequency * 10 })))
      .padding(5)
      .rotate(() => ~~(Math.random() * 2) * 90) // 0° o 90°
      .fontSize(d => d.size)
      .on('end', setWords);
    
    layout.start();
  }, [keywords]);
  
  return (
    <svg width={width} height={height}>
      <g transform={`translate(${width / 2}, ${height / 2})`}>
        {words.map((word, i) => (
          <text
            key={i}
            style={{
              fontSize: word.size,
              fill: colorScale(word.category),
              cursor: 'pointer'
            }}
            textAnchor="middle"
            transform={`translate(${word.x}, ${word.y}) rotate(${word.rotate})`}
            onClick={() => updateFilter('keyword', word.text)}
          >
            {word.text}
          </text>
        ))}
      </g>
    </svg>
  );
}
```

**Best Practices**:
- ✅ Tamaño proporcional a frecuencia
- ✅ Color por categoría
- ✅ Click para filtrar insights por palabra
- ✅ Hover para mostrar frecuencia exacta

### 2.5 Force Graph (Topics/Entities)

**Uso**: Visualizar relaciones entre topics o entidades.

```javascript
import { forceSimulation, forceLink, forceManyBody, forceCenter } from 'd3-force';

function TopicForceGraph({ nodes, links }) {
  const svgRef = useRef();
  
  useEffect(() => {
    const svg = d3.select(svgRef.current);
    
    // Simulación de fuerzas
    const simulation = forceSimulation(nodes)
      .force('link', forceLink(links).id(d => d.id).distance(100))
      .force('charge', forceManyBody().strength(-300))
      .force('center', forceCenter(width / 2, height / 2))
      .on('tick', ticked);
    
    // Links
    const link = svg.selectAll('.link')
      .data(links)
      .join('line')
      .attr('class', 'link')
      .attr('stroke', '#999')
      .attr('stroke-width', d => Math.sqrt(d.value));
    
    // Nodes
    const node = svg.selectAll('.node')
      .data(nodes)
      .join('circle')
      .attr('class', 'node')
      .attr('r', d => d.size)
      .attr('fill', d => colorScale(d.category))
      .call(drag(simulation)) // Drag behavior
      .on('click', (event, d) => {
        // Expandir conexiones del nodo
        updateFilter('topic', d.id);
      });
    
    function ticked() {
      link
        .attr('x1', d => d.source.x)
        .attr('y1', d => d.source.y)
        .attr('x2', d => d.target.x)
        .attr('y2', d => d.target.y);
      
      node
        .attr('cx', d => d.x)
        .attr('cy', d => d.y);
    }
    
    return () => simulation.stop();
  }, [nodes, links]);
  
  return <svg ref={svgRef} width={width} height={height}></svg>;
}

// Drag behavior
function drag(simulation) {
  function dragstarted(event) {
    if (!event.active) simulation.alphaTarget(0.3).restart();
    event.subject.fx = event.subject.x;
    event.subject.fy = event.subject.y;
  }
  
  function dragged(event) {
    event.subject.fx = event.x;
    event.subject.fy = event.y;
  }
  
  function dragended(event) {
    if (!event.active) simulation.alphaTarget(0);
    event.subject.fx = null;
    event.subject.fy = null;
  }
  
  return d3.drag()
    .on('start', dragstarted)
    .on('drag', dragged)
    .on('end', dragended);
}
```

**Best Practices**:
- ✅ Drag para reorganizar manualmente
- ✅ Zoom para explorar clusters
- ✅ Click para expandir/colapsar nodos
- ✅ Color por categoría, tamaño por relevancia

