## 6. Testing

### 6.1 Test D3 Calculations

```javascript
// SankeyChart.test.js
import { sankey } from 'd3-sankey';

test('Sankey layout calculates correct node positions', () => {
  const nodes = [
    { name: 'A' },
    { name: 'B' }
  ];
  
  const links = [
    { source: 0, target: 1, value: 10 }
  ];
  
  const layout = sankey()
    .nodeWidth(15)
    .nodePadding(10)
    .extent([[0, 0], [100, 100]]);
  
  const result = layout({ nodes, links });
  
  expect(result.nodes[0].x0).toBeLessThan(result.nodes[1].x0);
  expect(result.nodes[0].y0).toBeDefined();
});
```

### 6.2 Test Filters

```javascript
// useDashboardFilters.test.js
import { renderHook, act } from '@testing-library/react-hooks';
import { DashboardProvider, useDashboardFilters } from './useDashboardFilters';

test('updateFilter updates specific filter', () => {
  const { result } = renderHook(() => useDashboardFilters(), {
    wrapper: DashboardProvider
  });
  
  act(() => {
    result.current.updateFilter('stage', 'ocr');
  });
  
  expect(result.current.filters.stage).toBe('ocr');
  expect(result.current.filters.timeRange).toBeNull();
});

test('clearAllFilters resets all filters', () => {
  const { result } = renderHook(() => useDashboardFilters(), {
    wrapper: DashboardProvider
  });
  
  act(() => {
    result.current.updateFilter('stage', 'ocr');
    result.current.updateFilter('status', 'active');
    result.current.clearAllFilters();
  });
  
  expect(result.current.filters.stage).toBeNull();
  expect(result.current.filters.status).toBeNull();
});
```

