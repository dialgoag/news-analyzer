# ==============================================================================
# NewsAnalyzer-RAG - Configuración
# ==============================================================================
#
# Copiar: cp .env.example .env
# Editar .env con tus valores y ejecutar: docker compose up -d
#
# ==============================================================================

# ==============================================================================
# 1. PLATAFORMA
# ==============================================================================
# Por defecto: docker compose up -d → CPU (Mac, Linux sin GPU)
# Con GPU NVIDIA: docker compose -f docker-compose.yml -f docker-compose.nvidia.yml up -d
GPU_TYPE=cpu

# ==============================================================================
# 2. POSTGRESQL (REQUERIDO)
# ==============================================================================
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=rag_enterprise
# DATABASE_URL se construye automáticamente en docker-compose.yml

# ==============================================================================
# 3. LLM PROVIDER (REQUERIDO - elegir uno)
# ==============================================================================
# openai: Usa API de OpenAI (requiere OPENAI_API_KEY)
# ollama: Usa Ollama local (requiere servicio ollama corriendo)
LLM_PROVIDER=openai

# --- OpenAI (si LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# --- Ollama (si LLM_PROVIDER=ollama) ---
# OLLAMA_HOST=ollama
# OLLAMA_PORT=11434
# LLM_MODEL=qwen3:14b-q4_K_M

# ==============================================================================
# 4. PUERTOS
# ==============================================================================
BACKEND_PORT=8000
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000

# ==============================================================================
# 5. SEGURIDAD
# ==============================================================================
# Generar con: openssl rand -hex 32
# JWT_SECRET_KEY=
# Password del admin inicial (si vacío, se genera uno aleatorio en logs)
# ADMIN_DEFAULT_PASSWORD=
# Orígenes permitidos para CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000

# ==============================================================================
# 6. OCR
# ==============================================================================
# ocrmypdf: Usa servicio OCR dedicado (recomendado, Mac/CPU)
# tika: Requiere imagen CUDA con Java (Dockerfile, no Dockerfile.cpu)
OCR_ENGINE=ocrmypdf
# OCR_SERVICE_HOST=ocr-service  # default en compose
# OCR_SERVICE_PORT=9999

# ==============================================================================
# 7. EMBEDDINGS
# ==============================================================================
EMBEDDING_MODEL=BAAI/bge-m3
RELEVANCE_THRESHOLD=0.35

# ==============================================================================
# 8. WORKERS (ajustar según recursos disponibles)
# ==============================================================================
PIPELINE_WORKERS_COUNT=20
OCR_PARALLEL_WORKERS=3
INSIGHTS_PARALLEL_WORKERS=3
CHUNKING_PARALLEL_WORKERS=6
INDEXING_PARALLEL_WORKERS=6

# ==============================================================================
# 9. OPCIONALES
# ==============================================================================
# QDRANT_API_KEY=
# MAX_UPLOAD_SIZE_MB=100
# LOG_LEVEL=INFO
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=100
# INSIGHTS_MAX_RETRIES=5
# INSIGHTS_THROTTLE_SECONDS=60
